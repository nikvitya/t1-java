<databaseChangeLog
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.5.xsd">

    <changeSet id="init" author="ECHasov">
        <sqlFile encoding="utf8" path="/db/changelog/2024/09/16-01-changelog-01.sql"/>
        <rollback/>
    </changeSet>

    <changeSet id="update-client" author="ECHasov">
        <sqlFile encoding="utf8" path="/db/changelog/2024/09/16-01-changelog-02.sql"/>
        <rollback/>
    </changeSet>


    <changeSet id="create-account" author="VN">
        <sqlFile encoding="utf8" path="/db/changelog/2025/20-01-changelog-01.sql"/>
        <rollback/>
    </changeSet>

    <changeSet id="create-transaction" author="VN">
        <sqlFile encoding="utf8" path="/db/changelog/2025/20-01-changelog-02.sql"/>
        <rollback/>
    </changeSet>

    <changeSet id="create-data_source_error_log" author="VN">
        <sqlFile encoding="utf8" path="/db/changelog/2025/20-01-changelog-03.sql"/>
        <rollback/>
    </changeSet>

    <include file="data/client.sql" relativeToChangelogFile="true"/>
    <include file="data/account.sql" relativeToChangelogFile="true"/>
    <include file="data/transaction.sql" relativeToChangelogFile="true"/>

</databaseChangeLog>